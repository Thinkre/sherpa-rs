{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "KeVoiceInput",
  "version": "0.0.1",
  "identifier": "com.kevoiceinput.app",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "KeVoiceInput",
        "width": 680,
        "height": 570,
        "minWidth": 680,
        "minHeight": 570,
        "resizable": true,
        "maximizable": false,
        "visible": true
      }
    ],
    "security": {
      "csp": {
        "default-src": ["'self'", "ipc:"],
        "script-src": ["'self'", "'unsafe-inline'", "'unsafe-eval'", "ipc:"],
        "style-src": ["'self'", "'unsafe-inline'"],
        "img-src": [
          "'self'",
          "data:",
          "tauri:",
          "asset:",
          "http://localhost:*",
          "https:"
        ],
        "font-src": ["'self'", "data:"],
        "connect-src": ["'self'", "http://localhost:*", "http://127.0.0.1:*", "https:", "ipc:"]
      },
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": ["**"],
          "requireLiteralLeadingDot": false
        }
      }
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "resources": ["resources/**/*"],
    "license": "MIT",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "files": {},
      "hardenedRuntime": true,
      "minimumSystemVersion": "10.13",
      "signingIdentity": "-",
      "entitlements": "Entitlements.plist"
    },
    "linux": {
      "rpm": {
        "compression": {
          "type": "none"
        }
      },
      "appimage": {
        "bundleMediaFramework": true,
        "files": {}
      }
    },
    "windows": {
      "signCommand": "trusted-signing-cli -e https://eus.codesigning.azure.net/ -a CJ-Signing -c cjpais-dev -d KeVoiceInput %1"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDYwMzgwQzI0Q0FCODIwNkUKUldSdUlMaktKQXc0WVBpK2Nmc1dXMDdDQjMyK3FrMFBhREx3SkxqQWFOVUJxWU5hVW1xYVhZZ0cK",
      "endpoints": [
        "https://raw.githubusercontent.com/Thinkre/KeVoiceInput/main/latest.json"
      ],
      "dangerousInsecureTransportProtocol": false
    }
  }
}
